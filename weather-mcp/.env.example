# Weather MCP Server Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Weather API Configuration
# ============================================================================
# OpenWeatherMap API Key (free tier available)
# Get your key at: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Weather API Base URL (change only for alternative providers)
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# ============================================================================
# Optional: Server Configuration
# ============================================================================
# Log level: trace, debug, info, warn, error, silent
LOG_LEVEL=info

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# Enable debug mode (verbose logging)
DEBUG=false

# Default units for weather data: metric, imperial, kelvin
DEFAULT_UNITS=metric

# Default language for weather descriptions
DEFAULT_LANGUAGE=en
